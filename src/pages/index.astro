---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Benefits from '../components/Benefits.astro';
import Categories from '../components/Categories.astro';
import ProductGrid from '../components/ProductGrid.astro';
import OfferCountdown from '../components/OfferCountdown.astro';
import BlogPreview from '../components/BlogPreview.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import Newsletter from '../components/Newsletter.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Inicio">
  <Header />

  <main>
    <Hero />
    <Benefits />
    <Categories />
    <ProductGrid />
    <OfferCountdown />
    
    <!-- Services Banner Section -->
    <section class="banner-services">
      <div class="container text-center text-white banner-content">
        <h2>Servicios Veterinarios y de Peluquería</h2>
        <p>No solo vendemos productos, cuidamos de su salud y belleza integralmente.</p>
        <a href="#" class="btn btn-outline banner-btn">Agendar Cita Ahora</a>
      </div>
    </section>

    <BlogPreview />
    <Testimonials />
    <FAQ />
    <Newsletter />
  </main>
  
  <Footer />
</Layout>

<style>
  .banner-services {
    background-color: var(--color-primary);
    background-image: radial-gradient(circle at top right, var(--color-primary-light), var(--color-primary));
    padding: 5rem 0;
    margin: 3rem 0;
    border-radius: var(--border-radius);
    max-width: 95%;
    margin-left: auto;
    margin-right: auto;
    box-shadow: var(--shadow-lg);
  }
  
  .banner-content h2 {
    font-size: 2.5rem;
    color: white;
    margin-bottom: 1rem;
    font-weight: 700;
  }
  
  .banner-content p {
    font-size: 1.2rem;
    margin-bottom: 2.5rem;
    opacity: 0.95;
  }
  
  .text-white {
    color: white;
  }

  .banner-btn {
    border-color: white;
    color: white;
  }

  .banner-btn:hover {
    background-color: white;
    color: var(--color-primary);
  }
</style>
