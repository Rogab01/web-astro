---
// Countdown target: 7 days from now (calculated client-side so it's always future)
---
<section class="offer-section">
  <div class="container">
    <div class="offer-card">
      <div class="offer-content">
        <span class="offer-tag">🔥 Oferta Limitada</span>
        <h2>Semana del <span>Mejor Amigo</span></h2>
        <p>Hasta <strong>30% OFF</strong> en alimentos premium, accesorios y juguetes seleccionados.</p>

        <div class="countdown" id="countdown">
          <div class="time-block">
            <span class="time-value" data-unit="days">00</span>
            <span class="time-label">Días</span>
          </div>
          <div class="time-block">
            <span class="time-value" data-unit="hours">00</span>
            <span class="time-label">Horas</span>
          </div>
          <div class="time-block">
            <span class="time-value" data-unit="minutes">00</span>
            <span class="time-label">Min</span>
          </div>
          <div class="time-block">
            <span class="time-value" data-unit="seconds">00</span>
            <span class="time-label">Seg</span>
          </div>
        </div>

        <a href="#" class="btn btn-primary">Ver Ofertas</a>
      </div>

      <div class="offer-visual">
        <div class="discount-badge">
          <span class="discount-percent">-30%</span>
          <span class="discount-label">descuento</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const target = Date.now() + 7 * 24 * 60 * 60 * 1000;

  function updateCountdown() {
    const now = Date.now();
    const diff = Math.max(0, target - now);

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
    const minutes = Math.floor((diff / (1000 * 60)) % 60);
    const seconds = Math.floor((diff / 1000) % 60);

    const pad = (n: number) => String(n).padStart(2, '0');

    const map: Record<string, string> = {
      days: pad(days),
      hours: pad(hours),
      minutes: pad(minutes),
      seconds: pad(seconds)
    };

    document.querySelectorAll<HTMLElement>('.time-value').forEach((el) => {
      const unit = el.dataset.unit;
      if (unit && map[unit] !== undefined) el.textContent = map[unit];
    });
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);
</script>

<style>
  .offer-section {
    padding: 4rem 0;
    background-color: var(--color-light);
  }

  .offer-card {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    border-radius: var(--border-radius);
    padding: 3rem;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 40px;
    box-shadow: var(--shadow-lg);
    position: relative;
    overflow: hidden;
  }

  .offer-card::before {
    content: '🐾';
    position: absolute;
    font-size: 12rem;
    opacity: 0.08;
    top: -20px;
    right: -20px;
    transform: rotate(-15deg);
  }

  .offer-content {
    color: white;
    position: relative;
    z-index: 1;
  }

  .offer-tag {
    display: inline-block;
    background-color: rgba(255,255,255,0.2);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 16px;
    backdrop-filter: blur(6px);
  }

  .offer-content h2 {
    font-size: 2.4rem;
    color: white;
    margin-bottom: 12px;
    line-height: 1.15;
  }

  .offer-content h2 span {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    padding: 0 10px;
    border-radius: 6px;
  }

  .offer-content p {
    font-size: 1.1rem;
    margin-bottom: 24px;
    opacity: 0.95;
  }

  .offer-content p strong {
    font-size: 1.3rem;
  }

  .countdown {
    display: flex;
    gap: 12px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .time-block {
    background: white;
    color: var(--color-dark);
    padding: 12px 16px;
    border-radius: var(--border-radius-sm);
    min-width: 70px;
    text-align: center;
    box-shadow: var(--shadow);
  }

  .time-value {
    display: block;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }

  .time-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-gray);
    text-transform: uppercase;
    margin-top: 4px;
    letter-spacing: 0.5px;
  }

  .offer-card .btn-primary {
    background-color: white;
    color: var(--color-primary);
  }

  .offer-card .btn-primary:hover {
    background-color: var(--color-dark);
    color: white;
  }

  .offer-visual {
    position: relative;
    z-index: 1;
  }

  .discount-badge {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
    transform: rotate(-10deg);
    animation: pulse 3s ease-in-out infinite;
  }

  .discount-percent {
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
  }

  .discount-label {
    font-size: 0.9rem;
    color: var(--color-gray);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 4px;
  }

  @keyframes pulse {
    0%, 100% { transform: rotate(-10deg) scale(1); }
    50% { transform: rotate(-10deg) scale(1.05); }
  }

  @media (max-width: 768px) {
    .offer-card {
      grid-template-columns: 1fr;
      padding: 2rem;
      text-align: center;
    }

    .offer-content h2 {
      font-size: 1.8rem;
    }

    .countdown {
      justify-content: center;
    }

    .offer-visual {
      order: -1;
      display: flex;
      justify-content: center;
    }

    .discount-badge {
      width: 130px;
      height: 130px;
    }

    .discount-percent {
      font-size: 2.2rem;
    }
  }
</style>
