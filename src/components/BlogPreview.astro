---
// BlogPreview Component
const posts = [
  {
    title: "5 tips para que tu perro sea feliz",
    date: "12 Oct 2023",
    image: "https://images.unsplash.com/photo-1548199973-03cce0bbc87b?auto=format&fit=crop&q=80&w=800",
    excerpt: "Descubre cómo mejorar la calidad de vida de tu mejor amigo con estos sencillos consejos diarios."
  },
  {
    title: "La mejor dieta para gatos de interior",
    date: "28 Sep 2023",
    image: "https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?auto=format&fit=crop&q=80&w=800",
    excerpt: "Aprende a elegir los alimentos adecuados para mantener a tu gato sano y en su peso ideal."
  },
  {
    title: "¿Cómo entrenar a tu cachorro?",
    date: "15 Sep 2023",
    image: "https://images.unsplash.com/photo-1583337130417-3346a1be7dee?auto=format&fit=crop&q=80&w=800",
    excerpt: "Guía paso a paso para enseñar los comandos básicos a tu nuevo compañero peludo."
  }
];
---
<section class="blog-preview">
  <div class="container text-center">
    <h2 class="section-title">Tips y Cuidados</h2>
    <p class="section-subtitle">Consejos de expertos para mantener a tu mascota sana y feliz.</p>
    
    <div class="blog-grid">
      {posts.map(post => (
        <article class="blog-card glass-card hover-float">
          <div class="blog-image">
            <img src={post.image} alt={post.title} loading="lazy" />
          </div>
          <div class="blog-content">
            <span class="blog-date">{post.date}</span>
            <h3 class="blog-title"><a href="#">{post.title}</a></h3>
            <p class="blog-excerpt">{post.excerpt}</p>
            <a href="#" class="read-more">Leer más &rarr;</a>
          </div>
        </article>
      ))}
    </div>
    
    <div class="blog-action">
      <a href="#" class="btn btn-outline">Ver Todos los Artículos</a>
    </div>
  </div>
</section>

<style>
  .blog-preview {
    background-color: var(--color-light);
  }
  
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 30px;
    margin-bottom: 40px;
  }
  
  .blog-card {
    text-align: left;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  
  .blog-image {
    height: 200px;
    overflow: hidden;
  }
  
  .blog-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .blog-card:hover .blog-image img {
    transform: scale(1.05);
  }
  
  .blog-content {
    padding: 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  
  .blog-date {
    font-size: 0.85rem;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 8px;
    display: block;
  }
  
  .blog-title {
    font-size: 1.25rem;
    color: var(--color-dark);
    margin-bottom: 12px;
    line-height: 1.4;
  }
  
  .blog-title a:hover {
    color: var(--color-primary);
  }
  
  .blog-excerpt {
    color: var(--color-gray);
    font-size: 0.95rem;
    margin-bottom: 20px;
    flex: 1;
  }
  
  .read-more {
    font-weight: 600;
    color: var(--color-dark);
    font-size: 0.95rem;
    display: inline-block;
    transition: color 0.2s ease;
  }
  
  .read-more:hover {
    color: var(--color-primary);
  }
  
  .blog-action {
    margin-top: 20px;
  }
</style>
