---
// Categories Component
const categories = [
  { name: 'Perros', icon: '🐕', color: '#FFF3E0' },
  { name: 'Gatos', icon: '🐈', color: '#E3F2FD' },
  { name: 'Aves', icon: '🦜', color: '#E8F5E9' },
  { name: 'Peces', icon: '🐠', color: '#E1F5FE' },
  { name: 'Pequeños', icon: '🐹', color: '#F3E5F5' },
  { name: 'Reptiles', icon: '🦎', color: '#FBE9E7' }
];
---
<section class="categories">
  <div class="container text-center">
    <h2 class="section-title">Comprar por Mascota</h2>
    <p class="section-subtitle">Encuentra exactamente lo que necesitas para tu tipo de mascota</p>
    
    <div class="categories-grid">
      {categories.map((cat) => (
        <a href="#" class="category-item hover-float">
          <div class="category-icon" style={`background-color: ${cat.color};`}>
            <span>{cat.icon}</span>
          </div>
          <h3>{cat.name}</h3>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .categories {
    background-color: var(--color-white);
  }
  
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 30px;
    margin-top: 40px;
  }
  
  .category-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    padding: 10px;
  }
  
  .category-icon {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3.5rem;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    border: 4px solid white;
    box-shadow: var(--shadow);
  }
  
  .category-item:hover .category-icon {
    border-color: var(--color-primary-light);
    transform: scale(1.1) rotate(5deg);
    box-shadow: var(--shadow-lg);
  }
  
  .category-item h3 {
    font-size: 1.25rem;
    color: var(--color-dark);
    font-weight: 700;
    transition: var(--transition);
  }
  
  .category-item:hover h3 {
    color: var(--color-primary);
  }
</style>
