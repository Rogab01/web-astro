---
import '../styles/index.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "La mejor tienda para tu mascota. Descubre productos premium para perros, gatos y más." } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Best Practices -->
    <title>{title} | PetGalaxy</title>
    <meta name="description" content={description} />
    
    <!-- Theme Color -->
    <meta name="theme-color" content="#FF7A00" />
  </head>
  <body>
    <slot />
  </body>
</html>
